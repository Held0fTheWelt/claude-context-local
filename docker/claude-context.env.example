# Copy this file to ~/.context/.env for the local Docker stack.
#
# The MCP server should still run on the host/WSL so it can see your project
# paths directly. This Docker stack provides Milvus, and optionally Ollama.

EMBEDDING_PROVIDER=Ollama
OLLAMA_MODEL=mxbai-embed-large:latest
OLLAMA_HOST=http://127.0.0.1:11434
EMBEDDING_DIMENSION=1024

MILVUS_ADDRESS=http://127.0.0.1:19530
MILVUS_TOKEN=

HYBRID_MODE=true
SPLITTER_TYPE=ast

# Keep idle overhead low. Re-index manually or touch ~/.context/.sync-trigger
# when you want a client-triggered refresh.
CLAUDE_CONTEXT_BACKGROUND_SYNC=false
CLAUDE_CONTEXT_TRIGGER_WATCHER=true
